{
  "name": "cnrv-mod-activity",
  "version": "1.0.0",
  "description": "CnRV Mod Activity — roster, monthly metrics, and staff scoring, packaged for Android and Windows.",
  "main": "electron/main.js",
  "scripts": {
    "build:css": "tailwindcss -i ./src/index.css -o ./www/dist/styles.css --minify",
    "build:js": "esbuild src/app.jsx --bundle --minify --outfile=www/dist/bundle.js --loader:.jsx=jsx --target=es2019",
    "build": "npm run build:js && npm run build:css",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npm run android:sync && npx cap open android",
    "electron:start": "npm run build && electron .",
    "electron:dist": "npm run build && electron-builder --win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@tailwindcss/cli": "^4.3.2",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2"
  },
  "build": {
    "appId": "com.cnrv.modactivity",
    "productName": "CnRV Mod Activity",
    "files": [
      "electron/**/*",
      "www/**/*",
      "!android/**"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "www/icons/icon-512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
